@page "{id:int}"
@model ChurchAttendanceApp.Pages.MemberDetailModel
@{
    ViewData["Title"] = Model.Member?.Name?? "Member Detail"; 
}
<section class="card m-2 text-bg-light border-success border-3 w-100" style="max-width: 1000px">
    <div class="card-header d-flex flex-column justify-content-center align-items-center px-3 px-md-5 py-3" style="background: #20c997">
        <h3 class="card-title mb-1 pb-0 fw-bolder text-center">@Model.Member.Name</h3>
        <p class="card-subtitle mb-0 pb-0 fw-semibold text-center">@Model.Member.MemberId</p>
    </div>
    <div class="card-body d-flex flex-column flex-lg-row gap-3">
        <div class="card text-bg-light border-success border-3 w-100">
            <div class="card-header d-flex flex-column justify-content-center align-items-center px-5 py-3" style="background: #20c997">
                <h5 class="card-title mb-1 pb-0 fw-semibold">Member Details</h5>
            </div>
            <div class="card-body">
                <form asp-page="/MemberDetail" asp-route-id="@Model.Member.Id" method="post" id="updateForm">
                    <input type="hidden" asp-for="Member.Id" />
                    <input type="hidden" asp-for="Member.MemberId" />
                    <input type="hidden" asp-for="Member.Name"/>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.MembershipStatus">Membership</label>
                        <input class="form-control" type="text" readonly asp-for="@Model.Member.MembershipStatus" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.Gender">Gender</label>
                        <input class="form-control" type="text" readonly asp-for="@Model.Member.Gender" />
                        <select class="form-control" hidden asp-for="@Model.Member.Gender">
                            <option value="" selected>Choose your gender...</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                            <option value="Prefer not to say">Prefer not to say</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.Birthday">Birthday</label>
                        <input class="form-control" type="date" readonly asp-for="@Model.Member.Birthday" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.DateBaptized">Date Baptized</label>
                        <input class="form-control" type="date" readonly asp-for="@Model.Member.DateBaptized" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.Address">Address</label>
                        <input class="form-control" type="text" readonly asp-for="@Model.Member.Address" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.Email">Email</label>
                        <input class="form-control" type="text" readonly asp-for="@Model.Member.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.Phone">Phone</label>
                        <input class="form-control" type="text" readonly asp-for="@Model.Member.Phone" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="@Model.Member.DateRegistered">Date Registered</label>
                        <input class="form-control" type="date" readonly asp-for="@Model.Member.DateRegistered" />
                    </div>
                    <div class="d-flex gap-2 align-items-end justify-content-end">
                        <button id="editBtn" class="btn btn-primary">Edit</button>
                        <button id="deleteBtn" class="btn btn-danger">Delete</button>
                        <button id="confirmBtn" type="submit" class="btn btn-success d-none">Confirm</button>
                        <button id="cancelBtn" class="btn btn-secondary d-none">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="container-fluid w-100 px-0">
            <div class="card table-responsive border border-success border-3 rounded">
                <div class="card-header d-flex flex-column justify-content-center align-items-center px-5 py-3" style="background: #20c997">
                    <h5 class="card-title mb-1 pb-0 text-center">Attendance Records</h5>
                </div>
                <table class="table table-hover table-striped table-bordered align-middle">
                    <thead>
                        <tr>
                            <td class="fw-semibold text-center" colspan="2">
                                @if (Model.CheckAttendance(Model.Member))
                                {
                                    <span class="btn btn-info fw-semibold">Present</span>
                                }
                                else
                                {
                                    <span class="btn btn-warning fw-semibold">Absent</span>
                                }
                            </td>
                        </tr>
                        <tr class="text-nowrap text-center fw-bold">
                            <td>Id</td>
                            <td>Date</td>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attendanceRecord in Model.AttendanceRecords)
                        {
                            <tr class="text-nowrap text-center">
                                <td>@attendanceRecord.Id</td>
                                <td>@attendanceRecord.AttendanceDate</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
<div class="toast-container position-fixed bottom-0 end-0 p-3 w-auto" style="z-index: 9999">
    <div id="deleteToast" class="toast w-auto" role="alert" data-bs-autohide="false">
        <div class="toast-header bg-danger text-white">
            <strong class="me-auto text-nowrap">Confirm Delete</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body">
            <p class="text-nowrap mb-2">Are you sure you want to delete <strong>@Model.Member.Name</strong>?</p>
            <div class="d-flex gap-2 justify-content-end">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="toast">Cancel</button>
                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Member.Id">
                    <input type="hidden" asp-for="Member.Id" />
                    <button type="submit" class="btn btn-danger btn-sm">Yes, Delete</button>
                </form>
            </div>
        </div>
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successToast" class="toast align-items-center text-white bg-info border-0 w-auto"
             role="alert" data-bs-autohide="true" data-bs-delay="3000">
            <div class="d-flex">
                <div class="toast-body fw-semibold d-flex flex-row gap-2 text-nowrap">
                    <i class="bi bi-check-lg"></i> @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto flex-shrink-0" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
</div>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const inputs = document.querySelectorAll('#updateForm input:not([type="hidden"])');
        const editBtn = document.getElementById('editBtn');
        const deleteBtn = document.getElementById('deleteBtn');
        const confirmBtn = document.getElementById('confirmBtn');
        const cancelBtn = document.getElementById('cancelBtn');

        const genderInput = document.querySelector('input[name="Member.Gender"]');
        const genderSelect = document.querySelector('select[name="Member.Gender"]');

        const deleteToast = new bootstrap.Toast(document.getElementById('deleteToast'));

        const originalValues = {};
        inputs.forEach(input => originalValues[input.name] = input.value);

        editBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();

            inputs.forEach(input => input.removeAttribute('readonly'));

            genderInput.setAttribute('hidden', true);
            genderInput.setAttribute('disabled', true);
            genderSelect.removeAttribute('hidden');
            genderSelect.value = genderInput.value;

            editBtn.classList.add('d-none');
            deleteBtn.classList.add('d-none');
            confirmBtn.classList.remove('d-none');
            cancelBtn.classList.remove('d-none');
        });

        cancelBtn.addEventListener('click', function(e) {
            e.preventDefault();

            inputs.forEach(input => input.value = originalValues[input.name]);
            inputs.forEach(input => input.setAttribute('readonly', true));

            genderInput.removeAttribute('hidden');
            genderInput.removeAttribute('disabled');
            genderSelect.setAttribute('hidden', true);

            editBtn.classList.remove('d-none');
            deleteBtn.classList.remove('d-none');
            confirmBtn.classList.add('d-none');
            cancelBtn.classList.add('d-none');
        });

        deleteBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            deleteToast.show();
        });

        const successToastEl = document.getElementById('successToast');
        if (successToastEl) {
            const successToast = new bootstrap.Toast(successToastEl);
            successToast.show();
        }
    });
</script>