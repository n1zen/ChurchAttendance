@page
@model ChurchAttendanceApp.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log In";
}

<button class="btn fw-semibold px-3 py-2 mb-4 align-self-start outline-primary-btn"
        onclick="history.back()">
    <i class="bi bi-arrow-left me-2"></i>Back
</button>

<div class="card border-0 shadow-sm w-100" style="max-width: 450px; border-radius: 12px; overflow: hidden;">
    <div class="px-4 py-4 text-center card-header-primary">
        <h3 class="fw-bold mb-1">Log In</h3>
        <p class="mb-0 small fw-medium header-subtext">Fort Andres Bonifacio Adventist Church</p>
    </div>
    <div class="card-body px-4 py-4" style="background: #fff;">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold muted-text"></label>
                <input asp-for="Input.Email" class="form-control input-border" placeholder="email@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label fw-semibold muted-text"></label>
                <input asp-for="Input.Password" class="form-control input-border" placeholder="Enter your password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label muted-text"></label>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn fw-semibold py-2 btn-fabac">
                    Log In
                </button>
            </div>
        </form>
    </div>
</div>