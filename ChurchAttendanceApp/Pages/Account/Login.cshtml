@page
@model ChurchAttendanceApp.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log In";
}
<button class="btn btn-primary"
        onclick="history.back()">
    <i class="bi bi-arrow-left me-2"></i> Back
</button>
<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh">
    <div class="card text-bg-light border-success border-3 w-100" style="max-width: 450px">
        <div class="card-header d-flex flex-column justify-content-center align-items-center px-5 py-3" style="background: #20c997">
            <h3 class="card-title mb-1 pb-0 fw-bolder">Log In</h3>
            <p class="card-subtitle mb-0 pb-0 fw-semibold">Fort Andres Bonifacio Adventist Church</p>
        </div>
        <div class="card-body px-4 py-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="email@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                    <input asp-for="Input.Password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label"></label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success fw-semibold">Log In</button>
                </div>
            </form>

            <p class="mt-3 text-center mb-0">
                Don't have an account? <a asp-page="/Account/SignUp" class="text-success fw-semibold">Sign up</a>
            </p>
        </div>
    </div>
</div>