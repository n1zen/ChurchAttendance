<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - FABAC</title>
    <link rel="icon" type="image/svg+xml" href="~/images/logos/logo-circle--white.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
    </head>
    <body class="d-flex flex-column min-vh-100">
        @{
            var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
        }

        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid px-3 px-md-5">
                <!-- Brand -->
                <a asp-page="/Index" class="navbar-brand fw-bold d-flex align-items-center gap-2 py-2">
                    <img src="~/images/logos/logo.svg" alt="SDA Logo" height="36" />
                    <div class="d-flex flex-column lh-sm">
                        <span class="fw-bold brand-name">
                            <span class="d-none d-lg-inline">Fort Andres Bonifacio Adventist Church</span>
                            <span class="d-lg-none">FABAC</span>
                        </span>
                        <span class="d-none d-lg-inline brand-subtitle">Seventh-day Adventist</span>
                    </div>
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler border-0 shadow-none" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav Items -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 fw-medium fabac-nav-link @(currentPage == "/Index" ? "fabac-nav-link--active" : "")"
                               asp-page="/Index">Home</a>
                        </li>
                        @inject Microsoft.AspNetCore.Identity.SignInManager<ChurchAttendanceApp.Models.AppUser> SignInManager
                        @if (SignInManager.IsSignedIn(User))
                        {
                            @inject Microsoft.AspNetCore.Identity.UserManager<ChurchAttendanceApp.Models.AppUser> UserManager
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-3 py-2 fw-medium fabac-nav-link @(currentPage == "/Members" ? "fabac-nav-link--active" : "")"
                                       asp-page="/Members">Members</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link px-3 py-2 fw-medium fabac-nav-link @(currentPage == "/AttendanceList" ? "fabac-nav-link--active" : "")"
                                       asp-page="/AttendanceList">Attendance</a>
                                </li>
                            }
                            <!-- Divider -->
                            <li class="nav-item d-none d-lg-flex align-items-center">
                                <div class="divider-inline"></div>
                            </li>

                            <!-- User chip -->
                            <li class="nav-item d-flex align-items-center gap-2 px-3 py-1 user-chip">
                                <i class="bi bi-person-circle"></i>
                                <span class="fw-medium small user-chip-text">
                                    @User.Identity!.Name
                                </span>
                            </li>

                            <!-- Log Out button -->
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout" class="m-0">
                                    <button type="submit" class="btn btn-sm fw-semibold px-4 py-2 btn-fabac">
                                        Log Out
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <!-- Divider -->
                            <li class="nav-item d-none d-lg-flex align-items-center">
                                <div class="divider-inline"></div>
                            </li>
                            <li class="nav-item">
                                <a class="btn fw-semibold px-4 py-2 btn-fabac" asp-page="/Account/Login">Admin Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <main class="d-flex flex-column justify-content-center align-items-center mt-5 px-3 flex-grow-1 pb-5">
            @RenderBody()
        </main>

        <footer class="mt-auto py-4">
            <div class="container-fluid px-3 px-md-5">
                <div class="row mb-4 align-items-center">
                    <div class="col-12 d-flex flex-column align-items-center justify-content-center gap-1">
                        <img src="~/images/logos/logo.svg" alt="SDA Logo" height="40" />
                        <h5 class="fw-bold mb-0 text-center footer-title">
                            Fort Andres Bonifacio Adventist Church
                        </h5>
                        <p class="mb-0 small text-center footer-sub">
                            Seventh-day Adventist Church
                        </p>
                    </div>
                </div>

                <hr class="my-3 footer-hr" />

                <div class="row gy-3">
                    <div class="col-12 col-md-6">
                        <h6 class="fw-bold mb-2 text-center text-md-start footer-title">Contact the Church</h6>
                        <div class="d-flex flex-column gap-1 align-items-center align-items-md-start">
                            <p class="mb-0 small d-flex align-items-center gap-2 contact-item">
                                <i class="bi bi-envelope-at-fill text-primary-custom"></i>
                                fortbonifaciochurch@gmail.com
                            </p>
                            <p class="mb-0 small d-flex align-items-center gap-2 contact-item">
                                <i class="bi bi-telephone-fill text-primary-custom"></i>
                                +639543792512
                            </p>
                            <p class="mb-0 small d-flex align-items-center gap-2 contact-item">
                                <i class="bi bi-pin-map-fill text-primary-custom"></i>
                                Cattleya St. corner Sampaguita Extn Zone 15 1217, Taguig, Metro Manila
                            </p>
                        </div>
                    </div>

                    <div class="col-12 col-md-6">
                        <h6 class="fw-bold mb-2 text-center text-md-end footer-title">Developer</h6>
                        <div class="d-flex flex-column gap-1 align-items-center align-items-md-end">
                            <p class="mb-0 small contact-item">Built by Louie Izen B. Torres</p>
                            <p class="mb-0 small d-flex align-items-center gap-2 contact-item">
                                <i class="bi bi-envelope-at-fill text-primary-custom"></i>
                                torresizen070204@gmail.com
                            </p>
                            <p class="mb-0 small d-flex align-items-center gap-2 contact-item">
                                <i class="bi bi-github text-primary-custom"></i>
                                <a href="https://github.com/n1zen" class="text-primary-custom">Github</a>
                            </p>
                        </div>
                    </div>
                </div>

                <hr class="my-3 footer-hr" />

                <p class="text-center mb-0 small copyright">
                    &copy; @DateTime.Now.Year
                    <span class="d-none d-lg-inline">Fort Andres Bonifacio Adventist Church</span>
                    <span class="d-lg-none">FABAC</span>. All rights reserved.
                </p>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>