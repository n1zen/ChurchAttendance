<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - FABAC</title>
    <link rel="icon" type="image/svg+xml" href="~/images/logos/logo-circle--white.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
    <body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg" style="background: #20c997">
        <div class="container-fluid px-3 px-md-5">
            <!-- Change the name to whatever the name of the church -->
            <a asp-page="/Index" class="navbar-brand fw-bold text-wrap d-flex align-items-center gap-2">
                <img src="~/images/logos/logo.svg" alt="SDA Logo" height="40" />
                <span class="d-none d-lg-inline">Fort Andres Bonifacio Adventist Church</span>
                <span class="d-lg-none">FABAC</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" asp-page="/Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" aria-current="page" asp-page="/Members">Members</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <main class="d-flex flex-column justify-content-center align-items-center mt-5 px-3 flex-grow-1 pb-5">
        @RenderBody()
    </main>
    <footer style="background: #20c997" class="mt-auto py-3">
        <div class="container-fluid px-3 px-md-5">
            <div class="row mb-3">
                <!-- Change with relevant church information -->
                <div class="col-12 d-flex flex-column align-items-center justify-content-center">
                    <img src="~/images/logos/logo.svg" alt="SDA Logo" height="40" />
                    <h5 class="fw-bold mb-1 text-center text-md-start">
                        Fort Andres Bonifacio Adventist Church
                    </h5>
                    <p class="mb-0 small text-center text-md-start">Seventh-day Adventist Church</p>
                </div>
            </div>
            <hr class="my-3 border-dark" />
            <div class="row gy-3 d-flex">
                <!-- Change with relevant church contacts -->
                <div class="col-12 col-md-6">
                    <h6 class="fw-bold-mb-1 text-center text-md-start">Contact the Church</h6>
                    <p class="mb-0 small text-center text-md-start">
                        <i class="bi bi-envelope-at-fill" style="font-size: 1rem;"></i>
                        fortbonifaciochurch@gmail.com
                    </p>
                        <p class="mb-0 small text-center text-md-start">
                            <i class="bi bi-telephone-fill" style="font-size: 1rem;"></i>
                        +639543792512
                    </p>
                        <p class="mb-0 small text-center text-md-start">
                            <i class="bi bi-pin-map-fill" style="font-size: 1rem;"></i>
                        Cattleya St. corner Sampaguita Extn Zone 15 1217, Taguig, Metro Manila
                    </p>
                </div>
                <!-- My own information (Louie Izen B. Torres) -->
                <div class="col-12 col-md-6">
                    <h6 class="fw-bold mb-1 text-center text-md-end">Developer</h6>
                    <p class="mb-0 small text-center text-md-end">Built by Louie Izen B. Torres</p>
                    <p class="mb-0 small text-center text-md-end">
                        <i class="bi bi-envelope-at-fill" style="font-size: 1rem;"></i>
                        torresizen070204@gmail.com
                    </p>
                    <p class="mb-0 small text-center text-md-end">
                        <i class="bi bi-github" style="font-size: 1rem;"></i>
                        <a href="https://github.com/n1zen" class="text-dark text-decoration-none">Github</a>
                    </p>
                </div>
            </div>
            <hr class="my-3 border-dark" />
            <!-- Copyright -->
            <p class="text-center text-wrap small mb-0">
                &copy; @DateTime.Now.Year <span class="d-none d-lg-inline">Fort Andres Bonifacio Adventist Church</span><span class="d-lg-none">FABAC</span>. All rights reserved.
            </p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
