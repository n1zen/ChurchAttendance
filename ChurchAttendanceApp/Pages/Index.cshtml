@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="d-flex flex-column align-items-center gap-4 w-100" style="max-width: 600px">

    <!-- Welcome Card -->
    <div class="card border-0 shadow-sm w-100" style="border-radius: 12px; overflow: hidden;">
        <div class="px-4 py-4 text-center" style="background: #20c997;">
            <h1 class="fw-bold mb-1" style="color: #fff; font-size: 1.8rem;">Welcome! Happy Sabbath!</h1>
            <p class="mb-0 small fw-medium" style="color: rgba(255,255,255,0.85);">
                Current registered members:
                <span class="fw-bold">@Model.MemberCount</span>
            </p>
        </div>
        <div class="card-body d-flex flex-column justify-content-center align-items-center py-4 px-4 gap-2 text-center"
             style="background: #fff;">
            @if (Model.DailyVerse != null)
            {
                <p class="fst-italic mb-1" style="color: #374151; line-height: 1.7;">
                    " @Model.DailyVerse.Text "
                </p>
                <p class="mb-0 fw-semibold small" style="color: #20c997;">
                    — @Model.DailyVerse.BookName @Model.DailyVerse.Chapter:@Model.DailyVerse.Verse
                </p>
            }
        </div>
    </div>

    <!-- Attendance Card -->
    <div class="card border-0 shadow-sm w-100" style="border-radius: 12px; overflow: hidden;">
        <div class="px-4 py-3 text-center" style="background: #20c997;">
            <h3 class="fw-bold mb-1" style="color: #fff;">Church Attendance</h3>
            <p class="mb-0 small fw-medium" style="color: rgba(255,255,255,0.85);">Select your option</p>
        </div>
        <div class="card-body d-flex flex-column flex-sm-row justify-content-around align-items-center gap-3 py-4"
             style="background: #fff;">
            <a class="btn fw-semibold px-4 py-2 w-100 w-sm-auto"
                   style="background: #20c997; color: #fff; border-radius: 8px; transition: background 0.2s; max-width: 200px;"
                   onmouseover="this.style.background='#17a589'"
                   onmouseout="this.style.background='#20c997'"
                   asp-page="/OldMember">
                <i class="bi bi-person-check me-2"></i>Find my name!
            </a>
            <a class="btn fw-semibold px-4 py-2 w-100 w-sm-auto"
                   style="background: transparent; color: #20c997; border: 2px solid #20c997; border-radius: 8px; transition: all 0.2s; max-width: 200px;"
                   onmouseover="this.style.background='#20c997'; this.style.color='#fff'"
                   onmouseout="this.style.background='transparent'; this.style.color='#20c997'"
                   asp-page="/NewMember">
                <i class="bi bi-person-plus me-2"></i>I'm new here!
            </a>
        </div>
    </div>

</div>

<!-- Toasts -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successToast" class="toast align-items-center text-white bg-info border-0 w-auto"
             role="alert" data-bs-autohide="true" data-bs-delay="3000">
            <div class="d-flex">
                <div class="toast-body fw-semibold d-flex flex-row gap-2 align-items-center text-nowrap">
                    <i class="bi bi-check-lg" style="font-size: 1.2rem;"></i> @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto flex-shrink-0" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <div id="warningToast" class="toast align-items-center text-white bg-warning border-0 w-auto"
             role="alert" data-bs-autohide="true" data-bs-delay="3000">
            <div class="d-flex">
                <div class="toast-body fw-semibold d-flex flex-row gap-2 align-items-center text-nowrap">
                    <i class="bi bi-exclamation-octagon-fill" style="font-size: 1.2rem;"></i> @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto flex-shrink-0" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const successToastEl = document.getElementById('successToast');
        if (successToastEl) {
            const successToast = new bootstrap.Toast(successToastEl);
            successToast.show();
        }
        const warningToastEl = document.getElementById('warningToast');
        if (warningToastEl) {
            const warningToast = new bootstrap.Toast(warningToastEl);
            warningToast.show();
        }
    });
</script>