@page
@model IndexModel
@{ ViewData["Title"] = "Home"; }
<section class="card m-2 text-bg-light border-success" style="width: 50%">
    <div class="card-header d-flex flex-column justify-content-center align-items-center px-5 py-3">
        <h1 class="card-title">Welcome! Happy Sabbath!</h1>
        <p class="card-text text-secondary">Current registered members: @Model.MemberCount</p>
    </div>
    <div class="card-body d-flex flex-column justify-content-center align-items-center pb-3 text-wrap">
        <!-- Random Bible Verse -->
        @if(Model.DailyVerse != null) {
            <blockquote class="p-0 m-0 text-center fst-italic" >
                " @Model.DailyVerse.Text "
            </blockquote>
        }
        @if(Model.DailyVerse != null) {
            <blockquote class="p-0 m-0 text-center">
                - @Model.DailyVerse.BookName, @Model.DailyVerse.Chapter:@Model.DailyVerse.Verse
            </blockquote>
        }
    </div>
</section>
<section class="card m-2 text-bt-light border-success " style="width: max-content">
    <!-- Lookup Form -->
    <div class="card-header d-flex flex-column justify-content-center align-items-center px-5 pb-1 pt-2">
            <h3 class="card-title">Church Attendance</h3>
            <p class="card-subtitle text-body-secondary">Select your option</p>
        </div>
    <div class="card-body d-flex flex-row justify-content-around">
        <button class="btn btn-primary" id="existing-member-btn">Find my name!</button>
        <button class="btn btn-primary" id="new-member-btn">I'm new here!</button>
    </div>
</section>