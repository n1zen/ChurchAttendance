@page
@model IndexModel
@{ ViewData["Title"] = "Home"; }
<section class="card m-2 text-bg-light border-success border-3 w-100" style="max-width: 600px">
    <div class="card-header d-flex flex-column justify-content-center align-items-center px-5 py-3" style="background: #20c997">
        <h1 class="card-title text-center">Welcome! Happy Sabbath!</h1>
        <p class="card-text text-center" style="color: #fff">Current registered members: @Model.MemberCount</p>
    </div>
    <div class="card-body d-flex flex-column justify-content-center align-items-center pb-3 text-wrap">
        <!-- Random Bible Verse -->
        @if(Model.DailyVerse != null) {
            <blockquote class="p-0 m-0 text-center fst-italic" >
                " @Model.DailyVerse.Text "
            </blockquote>
        }
        @if(Model.DailyVerse != null) {
            <blockquote class="p-0 m-0 text-center">
                - @Model.DailyVerse.BookName, @Model.DailyVerse.Chapter:@Model.DailyVerse.Verse
            </blockquote>
        }
    </div>
</section>
<section class="card m-2 text-bt-light border-success border-3 w-100" style="max-width: 600px">
    <!-- Lookup Form -->
    <div class="card-header d-flex flex-column justify-content-center align-items-center px-5 pb-1 pt-2" style="background: #20c997">
            <h3 class="card-title text-center">Church Attendance</h3>
            <p class="card-subtitle pb-2" style="color: #fff">Select your option</p>
        </div>
    <div class="card-body d-flex flex-column flex-sm-row justify-content-around gap-2">
        <a class="btn btn-primary" id="existing-member-btn" aria-current="page" asp-page="/OldMember">Find my name!</a>
        <a class="btn btn-primary" id="new-member-btn" aria-current="page" asp-page="/NewMember">I'm new here!</a>
    </div>
</section>