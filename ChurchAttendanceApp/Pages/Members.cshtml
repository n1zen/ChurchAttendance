@page
@model ChurchAttendanceApp.Pages.MembersModel
@{
    ViewData["Title"] = "Member List";
}

<div class="w-100" style="max-width: 1100px">
    <div class="mb-3 d-flex align-items-center justify-content-between gap-3">
        <button class="btn fw-semibold px-3 py-2 outline-primary-btn" onclick="history.back()">
            <i class="bi bi-arrow-left me-2"></i>Back
        </button>
        <a class="btn fw-semibold px-4 py-2 btn-fabac" asp-page="/NewMember">
            <i class="bi bi-person-plus me-2"></i>Register a Member
        </a>
    </div>

    <div class="mb-3">
        <h2 class="fw-bold mb-0" style="color: var(--color-text-primary);">List of Members</h2>
        <p class="mb-0 small muted-text">
            Date: <span class="fw-semibold member-id-text">@Model.dateToday</span>
        </p>
    </div>

    <div class="card border-0 shadow-sm card-rounded">
        <div class="px-4 py-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 card-header-primary">
            <span class="fw-semibold">
                <i class="bi bi-people-fill me-2"></i>Members
            </span>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <input id="memberSearch" type="text" class="form-control form-control-sm"
                       placeholder="Search members..." style="width: 180px; flex: 1;" />

                <select id="filterMembership" class="form-select form-select-sm" style="width: 160px; flex: 1;">
                    <option value="">All Members</option>
                    <option value="Member">Member</option>
                    <option value="Visitor">Visitor</option>
                </select>

                <select id="filterAttendanceStatus" class="form-select form-select-sm" style="width: 160px; flex: 1;">
                    <option value="">All Attendance</option>
                    <option value="Present">Present</option>
                    <option value="Absent">Absent</option>
                </select>
            </div>
            <span class="badge rounded-pill fw-semibold px-3 py-2 badge-muted align-self-start align-self-md-center">
                @Model.Members.Count(m => m.MembershipStatus == "Member") member@(Model.Members.Count(m => m.MembershipStatus == "Member") != 1 ? "s" : "")
            </span>
            <span class="badge rounded-pill fw-semibold px-3 py-2 badge-muted align-self-start align-self-md-center">
                @Model.Members.Count(m => m.MembershipStatus == "Visitor") visitor@(Model.Members.Count(m => m.MembershipStatus == "Visitor") != 1 ? "s" : "")
            </span>
        </div>

        <div class="card-body p-0">
            @if (!Model.Members.Any())
            {
                <div class="d-flex flex-column justify-content-center align-items-center py-5 gap-2">
                    <i class="bi bi-people" style="font-size: 2.5rem; color: var(--color-text-muted);"></i>
                    <h5 class="mb-0 fw-semibold" style="color: var(--color-text-muted);">No members registered yet.</h5>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="membersTable">
                        <thead>
                            <tr class="text-center table-header-bg">
                                <th class="text-nowrap py-3 fw-semibold">#</th>
                                <th class="text-nowrap py-3 fw-semibold">Member ID</th>
                                <th class="text-nowrap py-3 fw-semibold">Name</th>
                                <th class="text-nowrap py-3 fw-semibold">Membership Status</th>
                                <th class="text-nowrap py-3 fw-semibold">Attendance Status</th>
                                <th class="text-nowrap py-3 fw-semibold">Date Registered</th>
                                <th class="text-nowrap py-3 fw-semibold">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model.Members)
                            {
                                <tr class="text-center table-row-divider">
                                    <td class="text-nowrap py-3">@member.Id</td>
                                    <td class="text-nowrap fw-semibold py-3 member-id-text">@member.MemberId</td>
                                    <td class="text-nowrap py-3" style="color: var(--color-text-primary);">@member.Name</td>
                                    <td class="text-nowrap py-3">
                                        <span class="badge rounded-pill px-3 py-2 fw-medium badge-membership">@member.MembershipStatus</span>
                                    </td>
                                    <td class="text-nowrap py-3">
                                        @if (Model.CheckAttendance(member))
                                        {
                                            <span class="badge rounded-pill px-3 py-2 fw-semibold badge-present">Present</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2 fw-semibold badge-absent">Absent</span>
                                        }
                                    </td>
                                    <td class="text-nowrap py-3 muted-text">@member.DateRegistered</td>
                                    <td class="text-nowrap py-3">
                                        <a class="btn btn-sm fw-semibold px-3 btn-fabac" asp-page="/MemberDetail" asp-route-id="@member.Id">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3 w-auto" style="z-index: 9999">
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successToast" class="toast align-items-center text-white bg-info border-0 w-auto"
             role="alert" data-bs-autohide="true" data-bs-delay="3000">
            <div class="d-flex">
                <div class="toast-body fw-semibold d-flex flex-row gap-2 text-nowrap">
                    <i class="bi bi-check-lg"></i> @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto flex-shrink-0" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
</div>
@section Scripts {
    <style>

        /* Force headers centered */
        table#membersTable > thead > tr > th {
            text-align: center !important;
        }

        /* Remove white box from pagination container */
        .dataTables_wrapper .dataTables_paginate .pagination {
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            gap: 4px;
        }

        /* Center info and pagination */
        .dataTables_wrapper .dataTables_info {
            float: none !important;
            display: block !important;
            width: 100% !important;
            text-align: center !important;
            padding: 12px 16px 4px !important;
            font-size: 0.85rem;
        }

        .dataTables_wrapper .dataTables_paginate {
            float: none !important;
            display: flex !important;
            justify-content: center !important;
            align-items: center !important;
            width: 100% !important;
            padding: 4px 16px 14px !important;
        }

        /* Dark mode pagination */
        .dark-theme .dataTables_wrapper .dataTables_paginate .pagination {
            background: transparent !important;
        }

        .dark-theme .dataTables_wrapper .dataTables_paginate .page-item .page-link {
            background-color: transparent !important;
            color: var(--color-primary) !important;
            border: 2px solid var(--color-primary) !important;
            border-radius: 8px !important;
            font-weight: 600 !important;
            box-shadow: none !important;
        }

        .dark-theme .dataTables_wrapper .dataTables_paginate .page-item.active .page-link {
            background-color: var(--color-primary) !important;
            color: #fff !important;
        }

        .dark-theme .dataTables_wrapper .dataTables_paginate .page-item .page-link:hover {
            background-color: var(--color-primary) !important;
            color: #fff !important;
        }

        .dark-theme .dataTables_wrapper .dataTables_paginate .page-item.disabled .page-link {
            background-color: transparent !important;
            opacity: 0.4 !important;
        }
        /* Filter selects in card header */
        #filterAttendanceStatus,
        #filterMembership {
            background-color: #fff;
            color: #111;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 8px;
        }

        .dark-theme #filterAttendanceStatus,
        .dark-theme #filterMembership {
            background-color: var(--color-bg-muted);
            color: var(--color-text-primary);
            border-color: var(--color-border-strong);
        }

        /* Mobile responsiveness */
        @@media (max-width: 767px) {
            /* Stack card header vertically */
            .card-header-primary {
                flex-direction: column !important;
                align-items: flex-start !important;
                gap: 12px !important;
            }
                /* Make filters full width on mobile */
                .card-header-primary .d-flex.flex-wrap {
                    width: 100%;
                }

                .card-header-primary input,
                .card-header-primary select {
                    width: 100% !important;
                    flex: 1 1 100% !important;
                }
                /* Badge stays left-aligned on mobile */
                .card-header-primary .badge-muted {
                    align-self: flex-start;
                }
            /* Tighten up page padding on mobile */
            .dataTables_wrapper .dataTables_info {
                font-size: 0.78rem !important;
            }

            .dataTables_wrapper .dataTables_paginate .page-item .page-link {
                min-width: 30px !important;
                height: 30px !important;
                font-size: 0.8rem !important;
                padding: 0 6px !important;
                margin: 0 1px !important;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if ($.fn.DataTable.isDataTable('#membersTable')) {
                $('#membersTable').DataTable().destroy();
            }

            const table = $('#membersTable').DataTable({
                pageLength: 20,
                lengthChange: false,
                searching: true,
                dom: 'tip',
                order: [[0, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [2, 3, 5] },
                ],
                language: {
                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                    paginate: {
                        previous: '<i class="bi bi-chevron-left"></i>',
                        next: '<i class="bi bi-chevron-right"></i>'
                    }
                }
            });

            // Fix: use jQuery .on() instead of addEventListener
            // because DataTables may re-render the input on init
            $('#memberSearch').on('keyup', function() {
                table.search($(this).val()).draw();
            });

            $('#filterMembership').on('change', function() {
                table.column(2).search($(this).val() ? '^' + $(this).val() + '$' : '', true, false).draw();
            });

            $('#filterAttendanceStatus').on('change', function() {
                table.column(3).search($(this).val() ? '^' + $(this).val() + '$' : '', true, false).draw();
            });

            const successToastEl = document.getElementById('successToast');
            if (successToastEl) {
                new bootstrap.Toast(successToastEl).show();
            }
        });
    </script>
}